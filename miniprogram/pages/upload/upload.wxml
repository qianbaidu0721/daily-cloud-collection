<view class="page-upload">
  <!-- 顶部 -->
  <view class="upload-header" style="padding-top: {{statusBarHeight}}px">
    <view
      class="header-bar"
      style="height: {{navContentHeight}}px; padding-right: {{navPaddingRight}}px"
    >
      <text class="header-title">收集今日云朵</text>
      <text class="header-close" bindtap="onClose">✕</text>
    </view>
  </view>

  <scroll-view
    class="upload-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 图片选择 -->
    <view class="section">
      <view class="image-picker" bindtap="chooseImage">
        <block wx:if="{{tempImagePath}}">
          <image class="preview-image" src="{{tempImagePath}}" mode="aspectFill" />
          <view class="image-remove" catchtap="removeImage">✕</view>
        </block>
        <block wx:else>
          <text class="picker-plus">+</text>
          <text class="picker-hint">点击选择照片</text>
        </block>
      </view>
    </view>

    <!-- 心情 -->
    <view class="section">
      <text class="section-label">今天的心情</text>
      <view class="mood-options">
        <view
          wx:for="{{moods}}"
          wx:key="value"
          class="mood-item"
          data-value="{{item.value}}"
          data-label="{{item.label}}"
          bindtap="onMoodSelect"
        >
          <view class="mood-emoji {{form.mood === item.value ? 'active' : ''}}">
            <text>{{item.emoji}}</text>
          </view>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 云类型 -->
    <view class="section">
      <text class="section-label">云的类型</text>
      <view wx:if="{{cloudTypesLoading}}" class="type-loading">加载云类型...</view>
      <scroll-view wx:else class="type-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="type-row">
          <view
            wx:for="{{cloudTypes}}"
            wx:key="code"
            class="type-chip {{form.cloud_type === item.name ? 'active' : ''}}"
            data-name="{{item.name}}"
            bindtap="onTypeSelect"
          >{{item.name}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- 位置 -->
    <view class="section">
      <text class="section-label">位置</text>
      <view class="location-row">
        <view class="location-text" bindtap="onLocationTap">
          <text wx:if="{{locationLoading}}">正在获取位置...</text>
          <text wx:elif="{{locationFailed}}">点击选择位置</text>
          <text wx:else>{{locationDisplay}}</text>
        </view>
        <text class="location-refresh" bindtap="fetchLocation">🔄</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="section">
      <text class="section-label">一句话心情</text>
      <view class="note-wrap">
        <textarea
          class="note-input"
          placeholder="记录此刻的心情..."
          maxlength="200"
          value="{{form.note}}"
          focus="{{noteFocus}}"
          bindinput="onNoteInput"
        />
        <text class="note-count">{{noteLength}}/200</text>
      </view>
    </view>

    <!-- 共享到广场 -->
    <view class="section">
      <view class="share-row">
        <view class="share-text">
          <text class="section-label share-label">共享到广场</text>
          <text class="share-hint">他人可见云朵与心情，备注始终私密</text>
        </view>
        <switch checked="{{isPublic}}" color="#7EC8E3" bindchange="onPublicToggle" />
      </view>
    </view>
  </scroll-view>

  <!-- 底部提交 -->
  <view class="submit-bar">
    <view
      class="submit-btn {{canSubmit && !submitting ? '' : 'disabled'}}"
      hover-class="submit-btn-hover"
      catchtap="submitUpload"
    >
      <text wx:if="{{submitting}}">提交中...</text>
      <text wx:else>提交收集</text>
    </view>
  </view>

  <!-- 上传进度弹层 -->
  <view wx:if="{{showUploadProgress}}" class="upload-progress-mask">
    <view class="upload-progress-box">
      <text class="upload-progress-icon cloud-loading">☁️</text>
      <text class="upload-progress-title">
        {{uploadPhase === 'uploading' ? '正在上传云朵...' : '准备上传...'}}
      </text>
      <view class="upload-progress-bar">
        <view class="upload-progress-fill" style="width: {{uploadProgress}}%" />
      </view>
      <text class="upload-progress-percent">{{uploadProgress}}%</text>
    </view>
  </view>
</view>
