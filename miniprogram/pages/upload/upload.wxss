.page-upload {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
  overflow: hidden;
}

/* ========== 顶部 ========== */
.upload-header {
  flex-shrink: 0;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: var(--spacing-lg);
  box-sizing: border-box;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.header-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: var(--spacing-xs);
  line-height: 1;
}

/* ========== 滚动区 ========== */
.upload-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: var(--spacing-md) var(--spacing-lg);
}

.section {
  margin-bottom: var(--spacing-lg);
}

.section-label {
  display: block;
  font-size: var(--text-base);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
}

/* ========== 图片选择 ========== */
.image-picker {
  position: relative;
  width: 100%;
  height: 400rpx;
  border: 2rpx dashed var(--border-light);
  border-radius: var(--radius-card);
  background: var(--bg-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.picker-plus {
  font-size: 80rpx;
  color: var(--primary);
  line-height: 1;
  font-weight: 300;
}

.picker-hint {
  margin-top: var(--spacing-sm);
  font-size: var(--text-base);
  color: var(--text-secondary);
}

.preview-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.image-remove {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* ========== 心情（天气系） ========== */
.mood-options {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.mood-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.mood-emoji {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  line-height: 1;
  border: 4rpx solid #E8EDF2;
  border-radius: 50%;
  background: transparent;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.mood-emoji.active {
  border-color: #7EC8E3;
  background: #E8F4F8;
  transform: scale(1.1);
}

.mood-label {
  font-size: 20rpx;
  color: #8A9AA8;
  line-height: 1.2;
}

/* ========== 云类型 ========== */
.type-loading {
  padding: var(--spacing-sm) 0;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.type-scroll {
  width: 100%;
  white-space: nowrap;
}

.type-row {
  display: inline-flex;
  gap: var(--spacing-sm);
  padding-right: var(--spacing-lg);
}

.type-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-tag);
  font-size: var(--text-base);
  color: var(--text-primary);
  background: var(--bg-card);
  border: 1rpx solid var(--border-light);
  flex-shrink: 0;
}

.type-chip.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

/* ========== 位置 ========== */
.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-card);
  border: 1rpx solid var(--border-light);
}

.location-text {
  flex: 1;
  font-size: var(--text-base);
  color: var(--text-primary);
}

.location-refresh {
  font-size: 36rpx;
  padding: var(--spacing-xs);
  margin-left: var(--spacing-sm);
}

/* ========== 备注 ========== */
.note-wrap {
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  border: 1rpx solid var(--border-light);
  padding: var(--spacing-sm);
}

.note-input {
  width: 100%;
  height: 120rpx;
  font-size: var(--text-base);
  color: var(--text-primary);
  line-height: 1.6;
}

.note-count {
  display: block;
  text-align: right;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: var(--spacing-xs);
}

/* ========== 共享开关 ========== */
.share-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-card);
  border: 1rpx solid var(--border-light);
}

.share-text {
  flex: 1;
  margin-right: var(--spacing-md);
}

.share-label {
  margin-bottom: var(--spacing-xs);
}

.share-hint {
  display: block;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ========== 底部提交 ========== */
.submit-bar {
  flex-shrink: 0;
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-light);
  padding-bottom: env(safe-area-inset-bottom);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  font-size: var(--text-lg);
  font-weight: 600;
}

.submit-btn.disabled {
  opacity: 0.5;
}

.submit-btn-hover {
  opacity: 0.85;
}

/* ========== 上传进度弹层 ========== */
.upload-progress-mask {
  position: fixed;
  inset: 0;
  background: rgba(61, 74, 90, 0.55);
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
}

.upload-progress-box {
  width: 560rpx;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-card);
}

.upload-progress-icon {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: var(--spacing-md);
}

.upload-progress-title {
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
}

.upload-progress-bar {
  width: 100%;
  height: 16rpx;
  background: var(--border-light);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: var(--spacing-sm);
}

.upload-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  border-radius: 8rpx;
  transition: width 0.15s ease;
}

.upload-progress-percent {
  font-size: var(--text-sm);
  color: var(--text-secondary);
}
