.page-list {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ========== 顶部导航 ========== */
.page-header {
  flex-shrink: 0;
  background: #FFFFFF;
  border-bottom: 1rpx solid var(--border-light);
}

.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-md);
  box-sizing: border-box;
}

.nav-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  text-align: center;
}

.nav-action {
  position: absolute;
  right: var(--spacing-md);
  font-size: var(--text-sm);
  color: var(--primary);
  padding: var(--spacing-xs) var(--spacing-sm);
}

.nav-action.disabled {
  opacity: 0.5;
}

/* ========== 列表主体 ========== */
.list-body {
  padding: var(--spacing-sm) var(--spacing-xs) var(--spacing-lg);
  box-sizing: border-box;
}

/* ========== 骨架屏网格 ========== */
.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 calc(-1 * var(--spacing-xs));
}

.skeleton-grid__item {
  width: 50%;
  padding: 0 var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
  box-sizing: border-box;
}

/* ========== 瀑布流 ========== */
.waterfall {
  display: flex;
  flex-wrap: wrap;
  align-content: flex-start;
  margin: 0 calc(-1 * var(--spacing-xs));
}

.waterfall-item {
  width: 50%;
  padding: 0 var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
  box-sizing: border-box;
}

/* 卡片入场动画 */
.card-rise {
  opacity: 0;
  animation: card-rise 0.4s ease forwards;
}

@keyframes card-rise {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* ========== 空状态（沿用全局 empty-state-box） ========== */

/* ========== 加载更多 ========== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: var(--spacing-lg) var(--spacing-md);
  color: var(--text-secondary);
  font-size: var(--text-sm);
}

/* ========== 详情弹层 ========== */
.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(61, 74, 90, 0.55);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
}

.detail-panel {
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  max-height: 90vh;
  overflow-y: auto;
  width: 100%;
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.detail-image {
  width: 100%;
  border-radius: var(--radius-card);
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-xs);
  font-size: var(--text-base);
  color: var(--text-secondary);
  text-align: left;
}

.detail-date {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--primary-dark);
}

.detail-visibility {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--bg-page);
  border-radius: var(--radius-tag);
}

.detail-visibility-action {
  font-size: var(--text-sm);
  color: var(--primary);
}

.detail-close {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  z-index: 2;
  padding: 8rpx 20rpx;
  font-size: var(--text-sm);
  color: var(--text-secondary);
}

.detail-share-link {
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  text-align: center;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--primary-dark);
  background: rgba(126, 200, 227, 0.12);
  border-radius: var(--radius-tag);
}

.detail-actions {
  display: none;
}
