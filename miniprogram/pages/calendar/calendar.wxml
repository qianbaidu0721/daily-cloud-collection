<view class="page-calendar">
  <!-- 顶部：状态栏 + 胶囊占位，月份切换在下方独立一行 -->
  <view class="page-header" style="padding-top: {{statusBarHeight}}px">
    <view class="capsule-gap" style="height: {{navContentHeight}}px" />
    <view class="month-bar">
      <text class="month-arrow month-arrow--left" bindtap="prevMonth">◀</text>
      <view class="month-center">
        <text class="month-title">{{year}}年{{month}}月</text>
        <text wx:if="{{!isCurrentMonth}}" class="month-today" bindtap="goToToday">今天</text>
      </view>
      <text class="month-arrow month-arrow--right" bindtap="nextMonth">▶</text>
    </view>
  </view>

  <scroll-view class="calendar-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 加载中 -->
    <view wx:if="{{isLoading && calendarCells.length === 0}}" class="page-loading">
      <text class="page-loading__icon cloud-loading">☁️</text>
      <text class="page-loading__text">云朵加载中...</text>
      <text wx:if="{{loadingSlow}}" class="page-loading__text page-loading__text--slow">等一等，云朵正在飘来~</text>
    </view>

    <!-- 加载失败 -->
    <view wx:elif="{{loadFailed && calendarCells.length === 0}}" class="empty-state-box">
      <text class="empty-state-box__icon">☁️</text>
      <text class="empty-state-box__title">加载失败了</text>
      <text class="empty-state-box__sub">网络走丢了，检查一下~</text>
      <view class="empty-state-box__btn" bindtap="retryLoad">点击重试</view>
    </view>

    <view wx:else class="calendar-body {{isLoading ? 'calendar-body--loading' : ''}}">
      <!-- 日历卡片 -->
      <view class="calendar-card">
        <view class="weekday-row">
          <text
            wx:for="{{weekdays}}"
            wx:key="*this"
            wx:for-index="idx"
            class="weekday {{idx >= 5 ? 'weekend' : ''}}"
          >{{item}}</text>
        </view>

        <view class="calendar-grid fade-month {{monthAnimating ? 'fade-out' : 'fade-in'}}">
          <view
            wx:for="{{calendarCells}}"
            wx:key="date"
            class="day-cell {{item.isCurrentMonth ? '' : 'other-month'}}"
            data-date="{{item.date}}"
            bindtap="onDayTap"
          >
            <view class="day-inner {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}} {{item.hasCloud ? 'has-cloud' : ''}}">
              <text class="day-num">{{item.day}}</text>
              <text wx:if="{{item.hasCloud}}" class="cloud-dot" />
            </view>
          </view>
        </view>
      </view>

      <!-- 月度统计 -->
      <view class="stats-card">
        <view class="stats-row">
          <text class="stats-count">本月已收集 {{monthCloudCount}} 天</text>
          <text class="stats-total">共 {{daysInMonth}} 天</text>
        </view>
        <view class="stats-bar">
          <view
            class="stats-bar-fill"
            style="width: {{monthCloudCount && daysInMonth ? (monthCloudCount / daysInMonth * 100) : 0}}%"
          />
        </view>
      </view>

      <!-- 某月无记录空状态 -->
      <view wx:if="{{!isLoading && monthCloudCount === 0}}" class="month-empty">
        <text class="month-empty__icon">☁️</text>
        <text class="month-empty__text">这个月还没有收集云朵哦</text>
        <view class="month-empty__btn" bindtap="goCollect">去收集</view>
      </view>

      <!-- 选中日预览 -->
      <view wx:if="{{selectedDate}}" class="preview-section">
        <text class="section-title">{{selectedDisplayDate}}</text>

        <view wx:if="{{selectedHasCloud && selectedCloud}}" class="preview-card" bindtap="goToList">
          <image
            class="preview-thumb"
            src="{{selectedCloud.image_url}}"
            mode="aspectFill"
            catchtap="previewImage"
          />
          <view class="preview-info">
            <view class="preview-meta">
              <text class="preview-mood">{{selectedCloud.moodEmoji}}</text>
              <text class="preview-label">{{selectedCloud.moodLabel}}</text>
              <text wx:if="{{selectedCloud.is_public}}" class="preview-public">🌍</text>
            </view>
            <text wx:if="{{selectedCloud.location_city}}" class="preview-city">📍 {{selectedCloud.location_city}}</text>
            <text wx:if="{{selectedCloud.note}}" class="preview-note">{{selectedCloud.note}}</text>
            <text class="preview-link">在列表中查看 →</text>
            <view class="preview-share-btn" catchtap="goShareCard">✨ 制作分享卡片</view>
          </view>
        </view>

        <view wx:else class="preview-empty">
          <text class="preview-empty-icon">☁️</text>
          <text class="preview-empty-text">这天还没有收集云朵</text>
          <button
            wx:if="{{selectedDate === todayDate}}"
            class="btn-primary preview-btn"
            bindtap="goCollect"
          >去收集今日云朵</button>
        </view>
      </view>

      <!-- 本月记录列表 -->
      <view class="records-section">
        <text class="section-title">本月记录</text>

        <view wx:if="{{monthCloudList.length === 0 && !isLoading}}" class="records-empty">
          <text>还没有云朵记录，去拍第一朵云吧 ~</text>
          <view class="month-empty__btn records-empty__btn" bindtap="goCollect">去收集</view>
        </view>

        <view wx:else class="records-list">
          <view
            wx:for="{{monthCloudList}}"
            wx:key="id"
            class="record-item {{selectedDate === item.collect_date ? 'active' : ''}}"
            data-date="{{item.collect_date}}"
            bindtap="onRecordTap"
          >
            <image class="record-thumb" src="{{item.image_url}}" mode="aspectFill" />
            <view class="record-info">
              <text class="record-date">{{item.displayDate}}</text>
              <text class="record-meta">{{item.moodEmoji}} {{item.moodLabel}}</text>
            </view>
            <text wx:if="{{item.is_public}}" class="record-public">🌍</text>
            <text class="record-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
