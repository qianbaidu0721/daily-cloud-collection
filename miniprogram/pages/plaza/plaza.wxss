.page-plaza {
  min-height: 100vh;
  background: var(--bg-page);
}

.page-header {
  flex-shrink: 0;
  background: #FFFFFF;
  border-bottom: 1rpx solid var(--border-light);
}

.nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-md);
  box-sizing: border-box;
}

.nav-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.nav-subtitle {
  display: block;
  text-align: center;
  font-size: var(--text-sm);
  color: var(--text-secondary);
  padding: 0 var(--spacing-md) var(--spacing-sm);
}

.plaza-body {
  padding: var(--spacing-sm) var(--spacing-xs) var(--spacing-lg);
  box-sizing: border-box;
}

.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 calc(-1 * var(--spacing-xs));
}

.skeleton-grid__item {
  width: 50%;
  padding: 0 var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
  box-sizing: border-box;
}

.waterfall {
  display: flex;
  flex-wrap: wrap;
  align-content: flex-start;
  margin: 0 calc(-1 * var(--spacing-xs));
}

.waterfall-item {
  width: 50%;
  padding: 0 var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
  box-sizing: border-box;
}

.waterfall-item__inner {
  position: relative;
  width: 100%;
}

.image-skeleton {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  border-radius: var(--radius-card);
  background: linear-gradient(90deg, #E8EDF2 25%, #F3F6F9 50%, #E8EDF2 75%);
  background-size: 200% 100%;
  animation: skeleton-breathe 1.4s ease-in-out infinite;
  z-index: 1;
  pointer-events: none;
}

@keyframes skeleton-breathe {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.card-rise {
  opacity: 0;
  animation: card-rise 0.4s ease forwards;
}

@keyframes card-rise {
  from { opacity: 0; }
  to { opacity: 1; }
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: var(--spacing-lg) var(--spacing-md);
  color: var(--text-secondary);
  font-size: var(--text-sm);
}

.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(61, 74, 90, 0.55);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
}

.detail-panel {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  max-height: 90vh;
  overflow-y: auto;
  width: 100%;
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.detail-image {
  width: 100%;
  border-radius: var(--radius-card);
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-xs);
  font-size: var(--text-base);
  color: var(--text-secondary);
  text-align: left;
}

.detail-date {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--primary-dark);
}
