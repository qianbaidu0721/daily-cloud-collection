/**
 * 云屿集 · 全局 Design System
 * 风格：治愈系极简
 */

/* ========== CSS 变量 ========== */
page {
  --primary: #7EC8E3;
  --primary-light: #B5DFF0;
  --primary-dark: #5BB5D8;
  --secondary: #F5C6A0;
  --secondary-light: #FBE8D6;
  --bg-page: #F0F4F8;
  --bg-card: #FFFFFF;
  --bg-muted: #F7F9FB;
  --text-primary: #3D4A5A;
  --text-secondary: #8A9AA8;
  --border-light: #E8EDF2;
  --shadow-card: 0 4rpx 20rpx rgba(126, 200, 227, 0.15);
  --radius-card: 16rpx;
  --radius-tag: 8rpx;
  --font-base: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;

  /* 字号规范 */
  --text-xl: 40rpx;
  --text-lg: 32rpx;
  --text-base: 28rpx;
  --text-sm: 24rpx;

  /* 间距规范 */
  --spacing-lg: 40rpx;
  --spacing-md: 24rpx;
  --spacing-sm: 16rpx;
  --spacing-xs: 8rpx;

  background-color: var(--bg-page);
  color: var(--text-primary);
  font-family: var(--font-base);
  font-size: var(--text-base);
  font-weight: 400;
  box-sizing: border-box;
  line-height: 1.5;
}

/* ========== 基础重置 ========== */
view,
text,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

button {
  font-family: var(--font-base);
  line-height: 1.4;
}

button::after {
  border: none;
}

/* ========== 布局 ========== */
.container {
  min-height: 100vh;
  padding: var(--spacing-md) var(--spacing-lg) var(--spacing-lg);
}

/* ========== 卡片 ========== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

/* ========== 按钮 ========== */
.btn-primary {
  background: var(--primary);
  color: var(--bg-card);
  border-radius: var(--radius-card);
  font-size: var(--text-lg);
  font-weight: 600;
  border: none;
  padding: var(--spacing-md) 0;
  width: 100%;
}

.btn-primary[disabled] {
  background: var(--primary-light);
  color: rgba(255, 255, 255, 0.8);
}

.btn-secondary {
  background: var(--secondary);
  color: var(--text-primary);
  border-radius: var(--radius-card);
  font-size: var(--text-base);
  font-weight: 600;
  border: none;
  padding: var(--spacing-sm) 0;
}

.btn-ghost {
  background: rgba(126, 200, 227, 0.12);
  color: var(--primary-dark);
  border-radius: var(--radius-card);
  font-size: var(--text-base);
  font-weight: 400;
  border: none;
  padding: var(--spacing-sm) 0;
}

/* ========== 文字 ========== */
.text-xl {
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--text-primary);
}

.text-lg {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.text-base {
  font-size: var(--text-base);
  font-weight: 400;
  color: var(--text-primary);
}

.text-sm {
  font-size: var(--text-sm);
  font-weight: 400;
  color: var(--text-secondary);
}

.text-primary-color {
  color: var(--primary-dark);
}

/* ========== 标签 ========== */
.tag {
  display: inline-block;
  font-size: var(--text-sm);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-tag);
  background: rgba(126, 200, 227, 0.15);
  color: var(--primary-dark);
}

.tag-secondary {
  background: rgba(245, 198, 160, 0.35);
  color: var(--text-primary);
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--spacing-md) 0;
}

/* ========== 空状态 ========== */
.empty-tip {
  text-align: center;
  color: var(--text-secondary);
  font-size: var(--text-base);
  padding: var(--spacing-lg) 0;
  line-height: 1.8;
}

/* ========== 遮罩 ========== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 74, 90, 0.45);
  z-index: 100;
}

/* ========== 底部面板 ========== */
.bottom-sheet {
  width: 100%;
  max-height: 85vh;
  background: var(--bg-card);
  border-radius: var(--radius-card) var(--radius-card) 0 0;
  padding: var(--spacing-lg);
  overflow-y: auto;
}

.bottom-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.bottom-sheet-title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.bottom-sheet-close {
  font-size: var(--text-lg);
  color: var(--text-secondary);
  padding: var(--spacing-xs);
}

/* ========== 输入框 ========== */
.input-box {
  width: 100%;
  min-height: 120rpx;
  padding: var(--spacing-sm);
  background: var(--bg-muted);
  border-radius: var(--radius-card);
  font-size: var(--text-base);
  color: var(--text-primary);
  border: 1rpx solid var(--border-light);
}

/* ========== 全局动画 ========== */
@keyframes cloud-float {
  0% { transform: translateY(0); opacity: 0.6; }
  50% { transform: translateY(-20rpx); opacity: 1; }
  100% { transform: translateY(0); opacity: 0.6; }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.45; }
}

@keyframes dot-bounce {
  0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-6rpx); }
}

.cloud-loading {
  animation: cloud-float 2s ease-in-out infinite;
}

.pulse {
  animation: pulse 1.5s ease-in-out infinite;
}

/* ========== 页面加载 ========== */
.page-loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
  min-height: 400rpx;
}

.page-loading__icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: var(--spacing-md);
}

.page-loading__text {
  font-size: var(--text-base);
  color: var(--text-secondary);
}

.page-loading__text--slow {
  margin-top: var(--spacing-sm);
  font-size: var(--text-sm);
  color: var(--primary);
}

/* ========== 空状态（通用） ========== */
.empty-state-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120rpx var(--spacing-lg) var(--spacing-lg);
}

.empty-state-box__icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: var(--spacing-md);
}

.empty-state-box__icon--lg {
  font-size: 160rpx;
}

.empty-state-box__title {
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

.empty-state-box__sub {
  font-size: var(--text-base);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-lg);
  line-height: 1.6;
}

.empty-state-box__btn {
  padding: 20rpx 60rpx;
  border-radius: var(--radius-card);
  background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  font-size: var(--text-base);
  font-weight: 600;
  line-height: 1.4;
}

/* ========== 骨架屏（通用） ========== */
.skeleton-card {
  background: var(--bg-card);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.skeleton-card__image {
  height: 240rpx;
  background: #E8EDF2;
  animation: pulse 1.5s ease-in-out infinite;
}

.skeleton-card__line {
  height: 24rpx;
  margin: var(--spacing-sm) var(--spacing-md);
  border-radius: 6rpx;
  background: #E8EDF2;
  animation: pulse 1.5s ease-in-out infinite;
}

.skeleton-card__line--short {
  width: 50%;
}

/* ========== 加载更多 ========== */
.load-more-dots {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 4rpx;
}

.load-more-dots text {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--text-secondary);
  animation: dot-bounce 1.2s ease-in-out infinite;
}

.load-more-dots text:nth-child(2) {
  animation-delay: 0.15s;
}

.load-more-dots text:nth-child(3) {
  animation-delay: 0.3s;
}

.load-more-retry {
  color: var(--primary-dark);
  font-weight: 600;
  padding: var(--spacing-xs) var(--spacing-sm);
}

/* ========== 图片占位 ========== */
.img-placeholder {
  position: absolute;
  inset: 0;
  background: #E8EDF2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.img-placeholder__icon {
  font-size: 48rpx;
  opacity: 0.45;
  animation: pulse 1.5s ease-in-out infinite;
}

.img-placeholder__error {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  margin-top: var(--spacing-xs);
}

.img-placeholder__retry {
  margin-top: var(--spacing-xs);
  font-size: var(--text-sm);
  color: var(--primary-dark);
  font-weight: 600;
  padding: var(--spacing-xs) var(--spacing-sm);
}

.cloud-card--large .img-placeholder {
  min-height: 400rpx;
}

.cloud-card--small .img-placeholder {
  min-height: 200rpx;
}
