.cloud-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.cloud-card__image-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
}

/* large：固定展示高度 400rpx，超出裁剪 */
.cloud-card--large .cloud-card__image-wrap {
  max-height: 400rpx;
}

.cloud-card--large .cloud-card__image {
  width: 100%;
  display: block;
}

/* small：图片自适应高度 */
.cloud-card--small .cloud-card__image {
  width: 100%;
  display: block;
  background: var(--bg-page);
}

.cloud-card__image--hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
}

/* 底部渐变信息条 */
.cloud-card__overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--spacing-md) var(--spacing-sm) var(--spacing-sm);
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.45) 100%);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--spacing-xs);
}

.cloud-card__date {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.cloud-card--large .cloud-card__date {
  font-size: var(--text-base);
  font-weight: 600;
}

.cloud-card__city {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.92);
}

.cloud-card__author {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.92);
}

/* 左上角共享角标 */
.cloud-card__visibility {
  position: absolute;
  top: var(--spacing-sm);
  left: var(--spacing-sm);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 右上角心情标签（天气系 Emoji） */
.cloud-card__mood {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.cloud-card--large .cloud-card__mood {
  width: 48rpx;
  height: 48rpx;
  font-size: 32rpx;
}

/* large 备注区 */
.cloud-card__note {
  padding: var(--spacing-md);
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: left;
}
