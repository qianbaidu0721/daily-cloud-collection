.mood-picker {
  width: 100%;
}

.mood-title {
  font-size: var(--text-base);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
}

.mood-list {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.mood-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.mood-emoji {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  line-height: 1;
  border: 4rpx solid #E8EDF2;
  border-radius: 50%;
  background: transparent;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.mood-item.active .mood-emoji {
  border-color: #7EC8E3;
  background: #E8F4F8;
  transform: scale(1.1);
}

.mood-label {
  font-size: 20rpx;
  color: #8A9AA8;
  line-height: 1.2;
}

.mood-item.active .mood-label {
  color: var(--primary-dark);
  font-weight: 600;
}
