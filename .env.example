APP_NAME="每日云彩收集"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL 数据库连接
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=daily_cloud
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# 管理后台初始账号（php artisan db:seed --class=AdminUserSeeder）
ADMIN_NAME=超级管理员
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# JWT 认证（部署后执行 php artisan jwt:secret 生成）
JWT_SECRET=
JWT_TTL=10080
JWT_REFRESH_TTL=43200
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true

# 微信小程序配置
WECHAT_APPID=
WECHAT_SECRET=

# 高德地图（经纬度逆解析城市）
AMAP_KEY=

# 文件存储（云朵照片）
FILESYSTEM_DISK=public
CLOUD_IMAGE_DISK=public

BROADCAST_CONNECTION=log
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# 分享卡片中文字体路径（TTF/OTF/TTC，服务器需安装）
# CLOUD_CARD_FONT=/path/to/NotoSansSC-Regular.otf
